# Create a new directory and enter it
function mkd() {
  mkdir -p "$@" && cd "$@"
}

# Determine size of a file or total size of a directory
function fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$@" ]]; then
    du $arg -- "$@"
  else
    du $arg .[^.]* *
  fi
}

# Use Git’s colored diff when available
hash git &>/dev/null
if [ $? -eq 0 ]; then
  function diff() {
    git diff --no-index --color-words "$@"
  }
fi

# Create a data URL from a file
function dataurl() {
  local mimeType=$(file -b --mime-type "$1")
  if [[ $mimeType == text/* ]]; then
    mimeType="${mimeType};charset=utf-8"
  fi
  echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')"
}

# Compare original and gzipped file size
function gz() {
  local origsize=$(wc -c < "$1")
  local gzipsize=$(gzip -c "$1" | wc -c)
  local ratio=$(echo "$gzipsize * 100/ $origsize" | bc -l)
  printf "orig: %d bytes\n" "$origsize"
  printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# Test if HTTP compression (RFC 2616 + SDCH) is enabled for a given URL.
# Send a fake UA string for sites that sniff it instead of using the Accept-Encoding header. (Looking at you, ajax.googleapis.com!)
function httpcompression() {
  encoding="$(curl -LIs -H 'User-Agent: Mozilla/5 Gecko' -H 'Accept-Encoding: gzip,deflate,compress,sdch' "$1" | grep '^Content-Encoding:')" && echo "$1 is encoded using ${encoding#* }" || echo "$1 is not using any encoding"
}

# Syntax-highlight JSON strings or files
# Usage: `json '{"foo":42}'` or `echo '{"foo":42}' | json`
function json() {
  if [ -t 0 ]; then # argument
    python -m json.tool <<< "$*" | pygmentize -l javascript
  else # pipe
    python -m json.tool | pygmentize -l javascript
  fi
}

# All the dig info
function digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}

# Escape UTF-8 characters into their 3-byte format
function escape() {
  printf "\\\x%s" $(printf "$@" | xxd -p -c1 -u)
  echo # newline
}

# Decode \x{ABCD}-style Unicode escape sequences
function unidecode() {
  perl -e "binmode(STDOUT, ':utf8'); print \"$@\""
  echo # newline
}

# Get a character’s Unicode code point
function codepoint() {
  perl -e "use utf8; print sprintf('U+%04X', ord(\"$@\"))"
  echo # newline
}

# Manually remove a downloaded app or file from the quarantine
function unquarantine() {
  for attribute in com.apple.metadata:kMDItemDownloadedDate com.apple.metadata:kMDItemWhereFroms com.apple.quarantine; do
    xattr -r -d "$attribute" "$@"
  done
}

# https://github.com/drush-ops/drush-launcher/issues/105
# Ensure drush runs from the project-local vendor bin.
function drush() {
  "$(git rev-parse --show-toplevel)/vendor/bin/drush" "$@"
}


# Time commands
function t() { TIMEFMT='%E'; time "$@"; }

# Frequent, security-first maintenance checks.
function update() {
  local brew_status="unavailable"
  local npm_status="unavailable"
  local composer_status="unavailable"
  local brew_outdated=""
  local composer_home=""
  local composer_output=""
  local composer_exit=0

  echo "==> Security-first update"
  echo

  echo "==> Homebrew"
  if command -v brew >/dev/null 2>&1; then
    if brew update; then
      brew_outdated="$(brew outdated 2>/dev/null)"
      if [[ -n "$brew_outdated" ]]; then
        printf '%s\n' "$brew_outdated"
        echo "Homebrew does not support first-class security-only upgrades."
        echo "If an advisory names a formula or cask, upgrade it explicitly with: brew upgrade <name>"
        brew_status="manual action"
      else
        echo "No outdated formulae or casks reported."
        brew_status="clean"
      fi
    else
      echo "brew update failed."
      brew_status="error"
    fi
  else
    echo "Homebrew is not installed."
  fi

  echo
  echo "==> npm"
  if command -v npm >/dev/null 2>&1; then
    echo "Global npm security audits are not supported by the npm CLI."
    echo "No automatic remediation was attempted."
    echo "Use \`upgrade-all\` for your broader monthly global npm updates."
    npm_status="manual review"
  else
    echo "npm is not installed."
  fi

  echo
  echo "==> Composer"
  if command -v composer >/dev/null 2>&1; then
    composer_home="$(composer global config home --absolute 2>/dev/null | tail -n 1)"
    if [[ -n "$composer_home" && -d "$composer_home" ]]; then
      composer_output="$(cd "$composer_home" && composer audit --format=summary --no-interaction 2>&1)"
      composer_exit=$?
      printf '%s\n' "$composer_output"

      if [[ $composer_exit -eq 0 ]]; then
        composer_status="clean"
      elif [[ $composer_exit -eq 1 ]]; then
        echo "Review the affected packages, then update only the impacted globals from $composer_home."
        composer_status="manual action"
      else
        echo "composer audit failed."
        composer_status="error"
      fi
    else
      echo "Composer global home could not be determined."
      composer_status="error"
    fi
  else
    echo "Composer is not installed."
  fi

  echo
  echo "Summary:"
  echo "  Homebrew: $brew_status"
  echo "  npm: $npm_status"
  echo "  Composer: $composer_status"
}

# Broader monthly maintenance updates.
function upgrade-all() {
  echo "==> Full maintenance upgrade"

  if command -v brew >/dev/null 2>&1; then
    echo
    echo "==> Homebrew"
    brew update
    brew upgrade
    brew cleanup
  fi

  if command -v npm >/dev/null 2>&1; then
    echo
    echo "==> npm"
    npm update -g
  fi

  if command -v gem >/dev/null 2>&1; then
    echo
    echo "==> RubyGems"
    gem update --system
  fi

  if command -v composer >/dev/null 2>&1; then
    echo
    echo "==> Composer"
    composer selfupdate
    composer global update
  fi

  echo
  echo "==> macOS"
  sudo softwareupdate -i -a
}
